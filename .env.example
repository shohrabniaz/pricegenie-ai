# Analytics: Vercel Analytics + Speed Insights work automatically on Vercel deploys.
# Enable in Vercel dashboard → Project → Analytics / Speed Insights.

# Optional: Upgrade AI Advisor to Groq (free tier available)
# GROQ_API_KEY=your_groq_api_key

# --- Email sign-in (Firebase Auth) ---
# Create a project at https://console.firebase.google.com
# Enable Authentication → Email/Password, then add a Web app for these values.
# Users must verify email before accessing the site when auth is enabled.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Enable auth gate in production (requires Firebase vars above). Leave unset for public launch.
# NEXT_PUBLIC_AUTH_ENABLED=true

# Disable auth gate (local dev / CI tests only)
# NEXT_PUBLIC_AUTH_DISABLED=true

# Optional: Live price feed (hosted JSON matching PriceSnapshot shape per product id)
# PRICE_FEED_URL=https://your-cdn.com/pricegenie-snapshots.json
# PRICE_FEED_API_KEY=

# Optional: Affiliate tracking (Phase 1 revenue — append to outbound shop links)
# NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=pricegenie-22
# NEXT_PUBLIC_EBAY_CAMPAIGN_ID=
