{
  "name": "pricegenie-ai",
  "version": "0.6.0",
  "description": "PriceGenie AI — Your wish for the best price granted",
  "author": "Shohrab Hossen Niaz <shohrab.niaz@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "eslint": "^9.39.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "sanity": "tsx scripts/sanity-check.ts",
    "launch:check": "tsx scripts/launch-check.ts",
    "prices:refresh": "tsx scripts/refresh-price-snapshots.ts",
    "prices:fetch-live": "tsx scripts/fetch-live-prices.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "check": "npm run lint && npm run typecheck && npm run test && npm run sanity && npm run build",
    "check:all": "npm run check && npm run test:e2e",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run sanity && npm run build",
    "docker:build": "docker build -t pricegenie-ai:local .",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "cheerio": "^1.2.0",
    "firebase": "^12.15.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
